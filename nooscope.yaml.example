vaults:
  - name: braintree
    path: /Volumes/Developer/BrainTree
    db_path: /Volumes/Developer/BrainTree/.nooscope/nooscope.db
    obsidian_mode: false           # set true to enable Obsidian-specific write paths (URI, REST, Templater)
    ignore:                        # paths/globs to skip during indexing (prefix or fnmatch)
      - Resources/Templates        # template files are structure, not content
      # - ResourcesDaily           # example: secondary folder to exclude
      # - "**/.obsidian/**"        # example: glob pattern

embeddings:
  semantic:
    backend: ollama
    model: nomic-embed-text
    dimensions: 768

chunking:
  max_tokens: 512
  strategy: headings
  moc_barycenter_weight: uniform

mcp:
  transport: stdio
  # host: 127.0.0.1
  # port: 8765

capture:
  # Structured note capture (queued, flushed as new files)
  flush_method: inbox             # inbox (default) | uri (obsidian_mode) | rest (obsidian_mode)
  inbox_folder: _inbox
  # obsidian_vault_name: BrainTree  # required for uri flush method (obsidian_mode only)
  # rest_port: 27123              # for rest method (obsidian_mode only)
  # rest_api_key: ""

  # Ephemeral log entries (direct write to today's daily note)
  daily_notes_folder: Resources/Daily
  daily_notes_format: "%Y-%m-%d"
  log_section: Notes              # ## heading name to append log entries under
  log_prefix: "- "               # bullet prefix; use "logger:: " for Obsidian Dataview queries
  daily_notes_template: "Resources/Templates/Daily Note.md"

calendar:
  enabled: false
  calendars: []                                    # empty = all calendars; or ["Work", "Personal"]
  agenda_section: Agenda                           # ## heading name to inject events under
  meetings_folder: References/Meetings
  meeting_template: Resources/Templates/Meeting.md
  # API keys must be set in the environment (ANTHROPIC_API_KEY), never in this file.
